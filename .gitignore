# Build artifacts (platform-specific)
Builds/
build/
*.o
*.obj

# IDE
.vscode/.cmaketools.json
.vscode/c_cpp_properties.json
.vscode/settings.json
.idea/
.DS_Store

# Claude Code — local, machine-specific settings (never version)
.claude/settings.local.json

# Cache directories
.cache/

# Xcode
*.xcodeproj
*.xcworkspace
DerivedData/

# Visual Studio
.vs/
*.user
*.suo
*.vcxproj.user
*.sln

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
install_manifest.txt
Makefile

# Binaries
*.app
*.component
*.vst3
*.exe
*.dll
*.dylib
*.so
*.a
*.lib

# Debug symbols
*.pdb
*.dSYM

# Runtime logs (project-relative Logs/ at repo root)
Logs/
logs/

# Personal workspace (never version)
_local/

# BMad / Cursor — local skill cache (regenerated by BMad installer; never version)
.agents/

# Legacy root folders — ignore if recreated (lowercase P-001 leftovers)
Quality/
Workbench/
src/
assets/
tests/
builds/
docs/

# Keep the canonical, versioned Tests/ directory: on case-insensitive filesystems
# (macOS) the lowercase "tests/" rule above also matches "Tests/", so re-include it.
# Nested lowercase "tests/" folders (e.g. inside tooling) stay ignored.
!/Tests/
!/Source/GUI/Tests/

# Temporary files
*.log
*~
*.bak
*.swp
