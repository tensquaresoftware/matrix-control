# Build artifacts (platform-specific)
Builds/
build/
*.o
*.obj

# IDE
.vscode/.cmaketools.json
.vscode/c_cpp_properties.json
.vscode/settings.json
.idea/
.DS_Store

# Claude Code — local, machine-specific settings (never version)
.claude/settings.local.json

# Cache directories
.cache/

# Xcode
*.xcodeproj
*.xcworkspace
DerivedData/

# Visual Studio
.vs/
*.user
*.suo
*.vcxproj.user
*.sln

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
install_manifest.txt
Makefile

# Binaries
*.app
*.component
*.vst3
*.exe
*.dll
*.dylib
*.so
*.a
*.lib

# Debug symbols
*.pdb
*.dSYM

# Runtime logs (project-relative Logs/ at repo root)
Logs/
logs/

# Personal workspace (never version)
_local/

# BMad / Cursor — local skill cache (regenerated by BMad installer; never version)
.agents/

# Abandoned P-001 lowercase root folders (canonical names are PascalCase: Source, Assets, Tests, Documentation).
# /src/ and /docs/ are safe guards on macOS — they do not collide with Source/ or Documentation/.
/src/
/docs/

# Legacy folders — ignore if recreated
Quality/
Workbench/

# Temporary files
*.log
*~
*.bak
*.swp
