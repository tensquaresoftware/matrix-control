{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset", "default-macos-arm64"
            ],
            "osx": {
                "args": [
                    "--preset", "default-macos-arm64"
                ]
            },
            "windows": {
                "args": [
                    "--preset", "default-windows"
                ]
            },
            "linux": {
                "args": [
                    "--preset", "default-linux"
                ]
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Configure if needed",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "test -d \"${command:cmake.buildDirectory}\" || cmake --preset default-macos-arm64"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "if (-not (Test-Path '${command:cmake.buildDirectory}')) { cmake --preset default-windows }"
                ]
            },
            "linux": {
                "args": [
                    "-c",
                    "test -d \"${command:cmake.buildDirectory}\" || cmake --preset default-linux"
                ]
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build: Standalone",
            "type": "shell",
            "dependsOn": ["CMake: Configure if needed"],
            "command": "cmake",
            "args": [
                "--build", "${command:cmake.buildDirectory}",
                "--target", "Matrix-Control_Standalone",
                "--config", "${command:cmake.buildType}"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build: AU",
            "type": "shell",
            "dependsOn": ["CMake: Configure if needed"],
            "command": "cmake",
            "args": [
                "--build", "${command:cmake.buildDirectory}",
                "--target", "Matrix-Control_AU",
                "--config", "${command:cmake.buildType}"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build: VST3",
            "type": "shell",
            "dependsOn": ["CMake: Configure if needed"],
            "command": "cmake",
            "args": [
                "--build", "${command:cmake.buildDirectory}",
                "--target", "Matrix-Control_VST3",
                "--config", "${command:cmake.buildType}"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build: All",
            "type": "shell",
            "dependsOn": ["CMake: Configure if needed"],
            "command": "cmake",
            "args": [
                "--build", "${command:cmake.buildDirectory}",
                "--config", "${command:cmake.buildType}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf", "Builds"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "Remove-Item -Recurse -Force Builds -ErrorAction SilentlyContinue"
                ]
            },
            "group": "build"
        },
        {
            "label": "Clean + Rebuild All",
            "dependsOn": [
                "Clean",
                "CMake: Configure",
                "Build: All"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build"
            },
            "problemMatcher": []
        }
    ]
}
