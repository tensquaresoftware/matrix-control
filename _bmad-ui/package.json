{
  "name": "bmad-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "sync-sessions:once": "node scripts/sync-sessions.mjs --once",
    "sync-sessions": "node scripts/sync-sessions.mjs",
    "check": "pnpm run check:lint && pnpm run check:types && pnpm run check:tests && pnpm run build",
    "build": "tsc --noEmit && vite build",
    "check:lint": "biome check src/",
    "check:types": "tsc --noEmit",
    "check:tests": "vitest run --passWithNoTests",
    "check:e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-query-devtools": "5.99.0",
    "@tanstack/react-router": "1.168.22",
    "echarts": "6.0.0",
    "marked": "18.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/marked": "6.0.0",
    "@types/node": "24.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
